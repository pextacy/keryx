# Web env — copy to .env.local (gitignored).
# URL of the agent's FastAPI service (server-side only; proxied by /api/ask).
AGENT_URL=http://127.0.0.1:8000

# --- Network (client-visible; must be NEXT_PUBLIC_ to reach the browser) ---
# Drives tx-link explorer + the network label. Keryx is testnet-only (Arc Testnet).
NEXT_PUBLIC_KERYX_NETWORK=testnet
NEXT_PUBLIC_ARC_EXPLORER=https://testnet.arcscan.app
