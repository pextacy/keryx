# Keryx environment — copy to .env (gitignored) and fill in.
# All keys are prefixed KERYX_ (see shared/config.py). Settlement economics have
# sane defaults; you mainly need the rail/db/LLM secrets.

# --- Settlement economics (config, not hardcoded) ---
KERYX_USDC_FLOOR=0.000001
KERYX_CITATION_TOLL_MIN=0.001
KERYX_CITATION_TOLL_MAX=0.01
KERYX_GROUNDING_THRESHOLD=0.5

# --- Chain / rail (Arc testnet) ---
# $RPC comes from arc-canteen: `arc-canteen shell-init >> ~/.zshrc`
KERYX_RPC_URL=
KERYX_ARC_CHAIN_ID=5042002           # 0x4cef52 — verified vs live RPC 2026-06-19
KERYX_GATEWAY_WALLET=0x0077777d7EBA4688BDeF3E311b846F25870A19B9
KERYX_USDC_ADDRESS=
# Settlement rail: 'mock' (default, zero-fund) or 'http' (bridges to rail/m0_spike/payer.ts).
KERYX_RAIL=mock
KERYX_PAYER_URL=http://localhost:3403/settle

# --- Off-chain store (Neon — NOT Supabase) ---
# Postgres + pgvector. Index/registry/cache only; chain is canonical. When set, the agent
# uses the Pg-backed store + settlement-ledger mirror (apply db/migrations/0001..0003 first);
# when blank it stays on the in-memory seeded registry + ledger (CI/zero-config default).
KERYX_DATABASE_URL=postgresql://USER:PASSWORD@HOST/DB?sslmode=require

# --- Chain-backed ledger verification (opt-in) ---
# When true (and RPC set), GET /ledger confirms each citation tx on Arc and reports on-chain
# amounts + reconciliation. Default false = mirror response, zero RPC reads (CI-safe).
KERYX_LEDGER_VERIFY_CHAIN=false
KERYX_CHAIN_RPC_TIMEOUT=8.0          # seconds per JSON-RPC call (>0)
KERYX_CHAIN_MAX_RETRIES=2            # transient-error retries before unverified (>=0)

# --- ERC-8004 agent identity + reputation (Arc Testnet registries) ---
# When enabled, GET /identity resolves the agent's on-chain ERC-8004 identity and
# POST /reputation records grounding-derived reputation (score = round(100*g)) as an
# external verifier. Reads need RPC; writes need KERYX_AGENT_PRIVATE_KEY. Default off.
KERYX_ERC8004_ENABLED=false
KERYX_AGENT_METADATA_URI=                 # ipfs://... metadata for register()
# Registry addresses default to the verified Arc Testnet contracts (docs.arc.io); override
# only if they change: KERYX_ERC8004_IDENTITY_REGISTRY / _REPUTATION_REGISTRY / _VALIDATION_REGISTRY

# --- ERC-8183 AgenticCommerce (job escrow) ---
# When enabled, GET /job/{id} reads on-chain job state; the lifecycle writes (create/fund/
# submit/complete) need KERYX_AGENT_PRIVATE_KEY. Default off (no RPC reads).
KERYX_ERC8183_ENABLED=false
# AgenticCommerce reference impl; override only if it changes:
# KERYX_ERC8183_CONTRACT=0x0747EEf0706327138c69792bF28Cd525089e4583

# --- Circle Developer-Controlled Wallets (W3S) ---
# Set the API key to enable programmatic wallet provisioning + contract execution (Gas
# Station sponsored). GET /circle/transaction/{id} reads tx status. Default off (no network).
# Writes also need an entitySecretCiphertext per call (generated via Circle tooling).
KERYX_CIRCLE_API_KEY=
KERYX_CIRCLE_API_BASE=https://api.circle.com

# --- API security (opt-in; default off keeps the open demo + CI) ---
# Set KERYX_API_KEY to require an X-API-Key header on the settlement/write endpoints
# (/payout, /bond, /stream, /royalties, /qf, /reputation). /ask + GET reads stay open.
# KERYX_RATE_LIMIT_PER_MINUTE caps requests per client IP across all endpoints (0 = off).
KERYX_API_KEY=
KERYX_RATE_LIMIT_PER_MINUTE=0

# --- Source ingest (RSSHub) ---
KERYX_RSSHUB_BASE_URL=http://localhost:1200
# Comma-separated routes to ingest (e.g. /github/trending/daily,/hackernews). Blank = use the
# seeded offline corpus (no fetch). Run: python -m registry.ingest_run
KERYX_RSSHUB_ROUTES=
KERYX_RSSHUB_TIMEOUT=20.0            # seconds per route fetch (>0)
KERYX_RSSHUB_MAX_RETRIES=2          # transient-error retries before skipping a route (>=0)

# --- LLM (grounding judge + answer synthesis) ---
# Set the API key to activate the real Claude judge + answerer (the moat); without it
# the agent uses the deterministic offline heuristics (CI/demo default).
KERYX_ANTHROPIC_API_KEY=
KERYX_JUDGE_MODEL=claude-opus-4-8
KERYX_ANSWER_MODEL=                  # blank -> same as JUDGE_MODEL
KERYX_JUDGE_EFFORT=low               # low|medium|high|max — grounding judge
KERYX_ANSWER_EFFORT=medium           # answer synthesis
KERYX_LLM_MAX_TOKENS=4096

# --- Embeddings (grounding similarity signal) ---
# Set the Voyage key to activate the dense embedder (semantic similarity); without it the
# similarity signal uses the offline BagOfWords TF-cosine (CI/demo default). Voyage is
# Anthropic's recommended embeddings provider — Anthropic ships no embeddings endpoint.
KERYX_VOYAGE_API_KEY=
KERYX_EMBEDDING_MODEL=voyage-3.5
# Client knobs — defaults are inert/offline-safe; they only take effect once a key is set.
KERYX_EMBEDDING_CONNECT_TIMEOUT=3.0    # seconds to establish a connection (>0)
KERYX_EMBEDDING_READ_TIMEOUT=10.0      # seconds to read a response (>0)
KERYX_EMBEDDING_MAX_RETRIES=2          # transient-error retries before degrading (>=0)
KERYX_EMBEDDING_BACKOFF_BASE=0.2       # base backoff seconds, doubled per attempt (>=0)
KERYX_EMBEDDING_BACKOFF_CAP=2.0        # max backoff seconds per sleep (>=0)
KERYX_EMBEDDING_BATCH_SIZE=128         # texts per Voyage POST (1..128)
KERYX_EMBEDDING_CACHE_SIZE=512         # max cached dense vectors, LRU-evicted (>=1)
KERYX_EMBEDDING_MAX_INPUT_CHARS=32000  # pre-truncate oversized inputs before send (>=1)
KERYX_EMBEDDING_DIMENSIONS=            # blank -> model default; else output_dimension
