# App Kit rail — copy to .env (gitignored).
# Funded Arc Testnet paying-agent key (0x-prefixed). Reuse the m0_spike BUYER wallet.
BUYER_PRIVATE_KEY=

# Arc RPC (matches KERYX_RPC_URL on the Python side). Blank -> viem's arcTestnet default.
ARC_RPC_URL=https://rpc.testnet.arc.network

# Circle kit key (free, from console.circle.com) — required ONLY for swap().
KIT_KEY=

# Optional: pay-server port (default 3404).
PAY_PORT=3404
