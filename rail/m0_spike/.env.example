# M0 spike env — copy to .env (gitignored), fill after `npm run generate-wallets`.
# Then fund AUTHOR_ADDRESS (the payee) and BUYER (the funder) with Arc testnet USDC
# at https://faucet.circle.com/ before `npm run m0`.

# Author / seller = the party that gets paid the citation toll.
AUTHOR_ADDRESS=
AUTHOR_PRIVATE_KEY=

# Buyer / funder = bankrolls the ephemeral agent wallet (this is what you fund).
BUYER_ADDRESS=
BUYER_PRIVATE_KEY=

# Seller endpoint the agent pays. Default local seller.ts.
SELLER_URL=http://localhost:3402/cite

# Toll for the single M0 citation (USDC). Sub-cent; above the $0.000001 floor.
M0_TOLL=0.001

# --- Network (network.ts) ---
# 'testnet' (default) = fully-verified Arc Testnet. 'mainnet' requires every
# KERYX_* chain value below to be supplied (verified vs Circle/Arc mainnet docs)
# or the spike refuses to start. The hackathon is testnet-only.
KERYX_NETWORK=testnet
# Blank = use the network preset; set to override (ALL required on mainnet):
KERYX_RPC_URL=
KERYX_ARC_CHAIN_ID=
KERYX_USDC_ADDRESS=
KERYX_GATEWAY_WALLET=
KERYX_CAIP2_NETWORK=
KERYX_EXPLORER_URL=
KERYX_GATEWAY_CLIENT_CHAIN=    # Circle SDK chain id; testnet preset: arcTestnet
