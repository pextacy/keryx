# Vendored upstreams. vendor/circle/ is committed in-tree (Circle's open-source repos, .git
# removed, LICENSEs kept — see vendor/circle/README.md + NOTICE). Other vendor dirs stay local.
/vendor/*
!/vendor/circle/
vendor/**/node_modules/
vendor/**/.env
vendor/**/.next/

